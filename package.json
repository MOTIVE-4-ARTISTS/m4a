{
  "name": "m4a",
  "version": "0.1.0",
  "private": true,
  "description": "motive4artists.org — MOtiVE 4 Artists Inc. (NY 501(c)(3) pending). See AGENTS.md.",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "seed:opportunities": "pnpm dlx tsx --require ./scripts/_tsx-bootstrap.cjs scripts/seed-opportunities.ts",
    "seed:events": "pnpm dlx tsx --require ./scripts/_tsx-bootstrap.cjs scripts/seed-events.ts",
    "knip": "knip",
    "secrets": "secretlint '**/*'",
    "qa": "pnpm lint && pnpm typecheck && pnpm knip && pnpm test && pnpm build",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.79",
    "@keystatic/core": "^0.5.50",
    "@keystatic/next": "^5.0.4",
    "@markdoc/markdoc": "^0.5.7",
    "@stripe/react-stripe-js": "^6.4.0",
    "@stripe/stripe-js": "^9.6.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "ai": "^6.0.191",
    "clsx": "^2.1.1",
    "d3-geo": "^3.1.1",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.3",
    "server-only": "^0.0.1",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.6.0",
    "topojson-client": "^3.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.2.0",
    "@playwright/test": "^1.49.0",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@tailwindcss/postcss": "^4",
    "@types/d3-geo": "^3.1.0",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/topojson-client": "^3.1.5",
    "knip": "^6.14.2",
    "lefthook": "^2.1.8",
    "secretlint": "^13.0.2",
    "tailwindcss": "^4",
    "typescript": "^5.7.0",
    "vitest": "^2.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver",
      "@biomejs/biome",
      "esbuild",
      "lefthook"
    ]
  }
}
