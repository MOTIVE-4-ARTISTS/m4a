{
  "name": "m4a",
  "version": "0.1.0",
  "private": true,
  "description": "motive4artists.org — MOtiVE 4 Artists Inc. (NY 501(c)(3) pending). See AGENTS.md.",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "tailwindcss": "^4",
    "typescript": "^5.7.0",
    "vitest": "^2.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver",
      "@biomejs/biome",
      "esbuild"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,mdx,css,yml,yaml}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
