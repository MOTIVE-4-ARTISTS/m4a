NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_EIN=

# Deployment surface: "full" (default) or "review". In "review" the site hides
# every not-yet-launched, service-dependent route (donations, applications,
# opportunities, events, admin, CMS) behind a real 404 and marks itself
# no-index, so a Vercel Preview can be shared for content/design review with no
# backend provisioned. See lib/site-mode.ts. Leave blank for normal local dev.
NEXT_PUBLIC_SITE_MODE=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@motive4artists.org

NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# /opportunities ingest pipeline.
# GOOGLE_GENERATIVE_AI_API_KEY: Gemini key powering extraction, the agentic
#   web discoverer, embeddings, and the "tell us about your practice" input.
#   Without it those steps no-op and rows fall back to lexical-only dedup.
# CRON_SECRET: shared bearer secret. Vercel Cron sends it automatically as
#   `Authorization: Bearer ${CRON_SECRET}`; the cron routes reject without it.
# OPPORTUNITIES_INBOX_WEBHOOK_SECRET: HMAC key the inbound-email provider signs
#   newsletter webhooks with (see app/api/inbound/email/route.ts).
GOOGLE_GENERATIVE_AI_API_KEY=
CRON_SECRET=
OPPORTUNITIES_INBOX_WEBHOOK_SECRET=
