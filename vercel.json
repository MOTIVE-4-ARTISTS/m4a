{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "sh scripts/vercel-ignore.sh",
  "crons": [
    { "path": "/api/cron/ingest", "schedule": "0 * * * *" },
    { "path": "/api/cron/discover", "schedule": "30 2,14 * * *" },
    { "path": "/api/cron/verify", "schedule": "0 7 * * *" }
  ]
}
